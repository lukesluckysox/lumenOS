# Generate a strong secret: openssl rand -base64 48
JWT_SECRET=change-this-to-a-long-random-string

# Set automatically by Railway
PORT=3000

# Set by Railway Volume — leave blank for local dev (uses ./lumen.db)
RAILWAY_VOLUME_MOUNT_PATH=

NODE_ENV=production

# Lumen loop — sub-app URLs for live dashboard stats + cross-app push
AXIOM_API_URL=https://axiomtool-production.up.railway.app
PRAXIS_API_URL=https://praxis-production-da89.up.railway.app
LIMINAL_API_URL=https://liminal-app.up.railway.app
LUMEN_INTERNAL_TOKEN=your-shared-internal-token
